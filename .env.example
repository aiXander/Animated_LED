# Copy to `.env` (gitignored) and fill in. Loaded automatically by `ledctl run`.
#
# OpenRouter — only needed for the Phase 6 chat agent. Render loop, REST API,
# and audio analysis all run fine without it; `/agent/chat` will return a 503.
OPENROUTER_API_KEY=

# Phase 8 prep: an alternative env-var name can be configured via
# `agent.api_key_env` in YAML. Default is OPENROUTER_API_KEY (above).
