project:
  name: festival_scaffold_dev
  target_fps: 60
server:
  host: 127.0.0.1
  port: 8000
controllers:
  gledopto_main:
    type: wled-ddp
    host: 127.0.0.1
    port: 4048
    pixel_count: 1800
strips:
- id: top_left
  controller: gledopto_main
  output: 1
  pixel_offset: 0
  pixel_count: 450
  leds_per_meter: 30.0
  geometry:
    type: line
    start:
    - 0.0
    - 0.5
    - 0.0
    end:
    - -15.0
    - 0.5
    - 0.0
  reversed: false
- id: top_right
  controller: gledopto_main
  output: 2
  pixel_offset: 450
  pixel_count: 450
  leds_per_meter: 30.0
  geometry:
    type: line
    start:
    - 0.0
    - 0.5
    - 0.0
    end:
    - 15.0
    - 0.5
    - 0.0
  reversed: false
- id: bottom_left
  controller: gledopto_main
  output: 3
  pixel_offset: 900
  pixel_count: 450
  leds_per_meter: 30.0
  geometry:
    type: line
    start:
    - 0.0
    - -0.5
    - 0.0
    end:
    - -15.0
    - -0.5
    - 0.0
  reversed: false
- id: bottom_right
  controller: gledopto_main
  output: 4
  pixel_offset: 1350
  pixel_count: 450
  leds_per_meter: 30.0
  geometry:
    type: line
    start:
    - -0.05
    - -0.5
    - 0.0
    end:
    - 14.95
    - -0.5
    - 0.0
  reversed: false
transport:
  mode: simulator
  sim:
    ws_path: /ws/frames
output:
  gamma: 2.2
audio:
  enabled: true
  # Pick interactively at http://127.0.0.1:8000/audio — the page writes the
  # chosen device name back here on save. `null` = system default input.
  device: null
  samplerate: 48000
  blocksize: 512
  channels: 1
  gain: 1.0
  smoothing: 0.4
